<?xml version="1.0" encoding="UTF-8" ?>
<XML>

<!-- Category
	default = 0 
	0 - 일반
	1 - 개인전
	2 - 팀전
	3 - 클랜전
	4 - 왕초보
	5 - 초보
	6 - 중수
	7 - 고수

	MSG태그의 id는 특정한 조건에만 발동될 경우를 위해서 만들어놓음.
-->

<!-- 일반 -->
<TIPS category="0">
