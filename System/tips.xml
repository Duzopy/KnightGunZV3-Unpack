	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>
	<MSG></MSG>


	<!-- GM Message -->
	<MSG></MSG>
	<MSG></MSG>

	<!-- 새로 추가 -->
	<MSG>I</MSG>
	<MSG></MSG>

	<!-- 클랜전 전용 -->
	<MSG></MSG>
	<MSG></MSG>
</TIPS>  

<!-- 왕초보 -->
<TIPS category="4">
	<MSG id="1"></MSG>
</TIPS>

<!-- 듀얼토너먼트 -->
<TIPS category="8">
	<MSG id="1"></MSG>
</TIPS>
</XML>
